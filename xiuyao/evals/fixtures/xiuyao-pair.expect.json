{
  "reading_type": "xiuyao-pair",
  "must_mention": [
    {
      "desc": "甲方本命宿心宿",
      "patterns": [
        "心宿"
      ]
    },
    {
      "desc": "乙方本命宿虚宿",
      "patterns": [
        "虚宿"
      ]
    },
    {
      "desc": "方向正确·甲方看乙方＝成",
      "patterns": [
        "甲方看乙方[^。]{0,5}成",
        "心宿看虚宿[^。]{0,5}成",
        "(?:乙方|虚宿)[^。]{0,4}(?:是|为)[^。]{0,4}(?:甲方|心宿)的[^。]{0,3}成"
      ]
    },
    {
      "desc": "方向正确·乙方看甲方＝危",
      "patterns": [
        "乙方看甲方[^。]{0,5}危",
        "虚宿看心宿[^。]{0,5}危",
        "(?:甲方|心宿)[^。]{0,4}(?:是|为)[^。]{0,4}(?:乙方|虚宿)的[^。]{0,3}危"
      ]
    },
    {
      "desc": "距离·中距离",
      "patterns": [
        "中距离"
      ]
    },
    {
      "desc": "关系组·危成",
      "patterns": [
        "危成"
      ]
    },
    {
      "desc": "值日宿昴",
      "patterns": [
        "值日宿[^。]{0,6}昴",
        "昴宿[^。]{0,8}值日"
      ]
    },
    {
      "desc": "六害位「克」如实标注",
      "patterns": [
        "六害[^。]{0,10}克",
        "克[^。]{0,6}六害"
      ]
    },
    {
      "desc": "历法边界提示",
      "patterns": [
        "差一宿",
        "历法边界",
        "农历[^。]{0,12}核对"
      ]
    }
  ],
  "forbidden": [
    {
      "desc": "方向反转·甲方看乙方≠危",
      "patterns": [
        "甲方看乙方[^。]{0,5}危",
        "心宿看虚宿[^。]{0,5}危"
      ]
    },
    {
      "desc": "方向反转·乙方看甲方≠成",
      "patterns": [
        "乙方看甲方[^。]{0,5}成",
        "虚宿看心宿[^。]{0,5}成"
      ]
    },
    {
      "desc": "捉造·不可能关系: 两人≠安坏",
      "patterns": [
        "(?:两人|二人|你们)[^。]{0,10}安坏",
        "(?:心宿|甲方)[^。]{0,8}(?:虚宿|乙方)[^。]{0,8}安坏"
      ]
    },
    {
      "desc": "捉造·不可能关系: 两人≠荣亲",
      "patterns": [
        "(?:两人|二人|你们)[^。]{0,10}荣亲",
        "(?:心宿|甲方)[^。]{0,8}(?:虚宿|乙方)[^。]{0,8}荣亲"
      ]
    },
    {
      "desc": "捉造·不可能关系: 两人≠命(同宿)",
      "patterns": [
        "(?:两人|二人|你们)[^。]{0,8}同宿",
        "(?:两人|二人|你们)[^。]{0,6}命的关系"
      ]
    },
    {
      "desc": "捉造·牛宿不存在于二十七宿",
      "patterns": [
        "牛宿"
      ]
    },
    {
      "desc": "红线: 安坏判死刑",
      "patterns": [
        "(?<![\\\"“「『/、不非])绝对不能在一起(?![\\\"”」』/、])",
        "(?<![\\\"“「『/、不非])相性最凶(?![\\\"”」』/、])",
        "(?<![\\\"“「『/、不非])注定(?:破裂|分开)(?![\\\"”」』/、])"
      ]
    },
    {
      "desc": "红线: 灾祸断言",
      "patterns": [
        "(?<![/、])血光(?![/、])",
        "(?<![/、])破财(?![/、])",
        "(?<![/、])病灾(?![/、])"
      ]
    },
    {
      "desc": "红线: 打分指数",
      "patterns": [
        "相性(?:得分|指数|评分)",
        "\\d{1,3}\\s*分的相性"
      ]
    }
  ],
  "must_flag": []
}
