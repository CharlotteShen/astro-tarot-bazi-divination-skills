{
  "reading_type": "hecan-pair",
  "must_mention": [
    {
      "desc": "甲方本命宿心宿",
      "patterns": [
        "心宿"
      ]
    },
    {
      "desc": "乙方本命宿角宿",
      "patterns": [
        "角宿"
      ]
    },
    {
      "desc": "宿曜方向正确·甲方看乙方＝成",
      "patterns": [
        "甲方看乙方[^。]{0,5}成",
        "心宿看角宿[^。]{0,5}成",
        "(?:乙方|角宿)[^。]{0,4}(?:是|为)[^。]{0,4}(?:甲方|心宿)的[^。]{0,3}成"
      ]
    },
    {
      "desc": "宿曜方向正确·乙方看甲方＝危",
      "patterns": [
        "乙方看甲方[^。]{0,5}危",
        "角宿看心宿[^。]{0,5}危",
        "(?:甲方|心宿)[^。]{0,4}(?:是|为)[^。]{0,4}(?:乙方|角宿)的[^。]{0,3}危"
      ]
    },
    {
      "desc": "八字轴真token（六冲/五合化土/七杀/大运 任一）",
      "patterns": [
        "六冲",
        "五合化土",
        "七杀",
        "大运[^。]{0,10}(同|不同)"
      ]
    },
    {
      "desc": "natal轴真token（月日合/日日六合/金火 任一）",
      "patterns": [
        "月亮[^。]{0,14}太阳",
        "Moon[^。]{0,25}Sun",
        "太阳[^。]{0,12}太阳",
        "金星[^。]{0,12}火星",
        "Venus[^。]{0,22}Mars"
      ]
    },
    {
      "desc": "紫微缺席声明",
      "patterns": [
        "紫微[^。]{0,25}(缺席|跳过|不适用|无双人|未纳入|无法)",
        "(不含|缺少|少了)[^。]{0,6}紫微"
      ]
    },
    {
      "desc": "natal降级声明",
      "patterns": [
        "(时辰未知|12:00)[^。]{0,30}(宫位|上升)",
        "宫位[^。]{0,20}不可用",
        "上升[^。]{0,15}不可用"
      ]
    },
    {
      "desc": "共振出现",
      "patterns": [
        "共振",
        "呼应"
      ]
    },
    {
      "desc": "分歧出现",
      "patterns": [
        "分歧",
        "各说各话",
        "张力"
      ]
    }
  ],
  "forbidden": [
    {
      "desc": "捉造·引用缺席紫微（星曜/宫位正面断言）",
      "patterns": [
        "(紫微|天府|贪狼|武曲|廉贞|七杀星|破军|天梁|太阴|巨门)[^。]{0,4}(坐守|入命|守命)",
        "(命宫|夫妻宫|官禄宫|财帛宫)[^。]{0,8}(主星|坐守)",
        "(紫微|天府|贪狼|武曲|廉贞|破军|天梁|太阴|巨门)[^。]{0,6}(坐|入|落)[^。]{0,6}宫"
      ]
    },
    {
      "desc": "捉造·降级宫位层断言（上升/宫位重叠）",
      "patterns": [
        "(上升|Ascendant|ASC)[^。]{0,10}(相位|合相|对分|四分|三合|六合)",
        "落[^。]{0,5}(对方|B)[^。]{0,5}的?第?[0-9一二三四五六七八九十]+宫",
        "宫位重叠[^。]{0,10}(显示|表明|说明)"
      ]
    },
    {
      "desc": "红线·一致性投票",
      "patterns": [
        "(都|一致)[^。]{0,14}(所以|因此|故)[^。]{0,10}(更|必然|肯定)",
        "(几?[三四多]个?体系|各体系)[^。]{0,8}(印证|投票|背书)"
      ]
    },
    {
      "desc": "红线·翻译对照（五行↔元素）",
      "patterns": [
        "[木火土金水](?:行)?[^。]{0,4}(对应|等于|就是|即是|＝)[^。]{0,4}[风火土水]象",
        "五行[^。]{0,6}(对应|映射|翻译)[^。]{0,6}四?元素"
      ]
    },
    {
      "desc": "红线·翻译对照（十神↔行星）",
      "patterns": [
        "(十神|官杀|七杀|正官|食伤|印星)[^。]{0,4}(就是|等于|即是|＝|对应)[^。]{0,6}(土星|木星|火星|水星|金星|行星|Saturn|Mars)"
      ]
    },
    {
      "desc": "红线·多重宿命",
      "patterns": [
        "命(更|变)硬",
        "(加倍|双重|更加)[^。]{0,4}注定",
        "印证[^。]{0,8}(宿命|注定)"
      ]
    },
    {
      "desc": "宿曜方向反转·甲方看乙方≠危",
      "patterns": [
        "甲方看乙方[^。]{0,5}危",
        "心宿看角宿[^。]{0,5}危"
      ]
    },
    {
      "desc": "红线: 判死刑词表",
      "patterns": [
        "(?<![\\\"“「『/、不非])绝对不能在一起(?![\\\"”」』/、])",
        "(?<![\\\"“「『/、不非])相性最凶(?![\\\"”」』/、])",
        "(?<![\\\"“「『/、不非])注定(?:破裂|分开)(?![\\\"”」』/、])"
      ]
    },
    {
      "desc": "红线: 灾祸断言",
      "patterns": [
        "(?<![/、])血光(?![/、])",
        "(?<![/、])破财(?![/、])",
        "(?<![/、])病灾(?![/、])"
      ]
    },
    {
      "desc": "红线: 打分指数",
      "patterns": [
        "相性(?:得分|指数|评分)",
        "\\d{1,3}\\s*分的相性"
      ]
    }
  ],
  "must_flag": []
}
